# Neon pooled connection string (runtime app traffic)
DATABASE_URL=postgresql://username:password@your-pooled-host.neon.tech/dbname?sslmode=require

# Neon direct connection string (Drizzle migrations)
DATABASE_URL_MIGRATIONS=postgresql://username:password@your-direct-host.neon.tech/dbname?sslmode=require

# Auth.js
AUTH_SECRET=replace-with-a-random-secret

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
